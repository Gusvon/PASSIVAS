<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arcano Pessoal 🎀✨</title>
    <!-- Fontes fofas e modernas: Fredoka para títulos e Nunito para textos -->
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        /* Fundo Mágico: Rosa, Branco e Azul Bebê (Estética Trans/Soft) */
        body {
            font-family: 'Nunito', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            background-color: #ffc0cb;
            background-image: 
                radial-gradient(at 20% 20%, #ff9a9e 0px, transparent 50%),
                radial-gradient(at 80% 80%, #5bcefa 0px, transparent 50%), /* Toque de azul bebê */
                radial-gradient(at 50% 50%, #ffffff 0px, transparent 60%);
            color: #6d4c5a;
            padding: 20px;
            box-sizing: border-box;
        }

        /* Cartão Glassmorphism (Vidro Fosco) */
        .card {
            background-color: rgba(255, 255, 255, 0.65);
            padding: 40px 30px;
            border-radius: 40px;
            box-shadow: 0 20px 40px rgba(255, 105, 180, 0.15);
            border: 2px solid rgba(255, 255, 255, 0.8);
            text-align: center;
            max-width: 420px;
            width: 100%;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        /* Títulos fofinhos */
        h1 {
            font-family: 'Fredoka', sans-serif;
            color: #ff3385;
            margin-top: 0;
            font-size: 32px;
            letter-spacing: 0.5px;
            text-shadow: 2px 2px 0px #ffffff;
        }

        p.subtitle {
            font-size: 15px;
            font-weight: 600;
            color: #b05c8a;
            margin-bottom: 25px;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        /* Campo de Data tipo Pílula */
        input[type="date"] {
            font-family: 'Nunito', sans-serif;
            padding: 16px 20px;
            border: 2px solid #f5a9b8; /* Rosa suave */
            border-radius: 30px;
            font-size: 16px;
            font-weight: 600;
            color: #ff3385;
            outline: none;
            transition: all 0.3s ease;
            background-color: rgba(255, 255, 255, 0.9);
            box-shadow: inset 0 2px 5px rgba(255, 182, 193, 0.2);
        }

        input[type="date"]:focus {
            border-color: #5bcefa; /* Azul bebê no foco */
            box-shadow: 0 0 15px rgba(91, 206, 250, 0.3);
        }

        /* Botão Glossy Pink */
        button {
            font-family: 'Fredoka', sans-serif;
            padding: 18px;
            background: linear-gradient(135deg, #ff7eb3, #ff758c);
            color: white;
            border: none;
            border-radius: 30px;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            box-shadow: 0 8px 20px rgba(255, 117, 140, 0.4);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        button:hover {
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 12px 25px rgba(255, 117, 140, 0.6);
            background: linear-gradient(135deg, #ff89b9, #ff8096);
        }

        button:active {
            transform: translateY(1px);
        }

        /* Área de Resultados */
        #area-resultado {
            margin-top: 30px;
            display: none;
            animation: bounceIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .passos-calculo {
            font-size: 14px;
            font-weight: 600;
            color: #9e6d81;
            margin-bottom: 12px;
            background: rgba(255, 255, 255, 0.7);
            padding: 12px;
            border-radius: 20px;
            border: 1px dashed #f5a9b8;
        }

        .resultado-destaque {
            font-family: 'Fredoka', sans-serif;
            font-size: 24px;
            color: #ffffff;
            background: linear-gradient(135deg, #ff758c, #ff7eb3);
            padding: 20px;
            border-radius: 25px;
            box-shadow: 0 10px 20px rgba(255, 117, 140, 0.3);
            text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
        }

        /* Seção Sanfona (Como funciona) */
        details {
            margin-top: 30px;
            background: rgba(255, 255, 255, 0.8);
            padding: 15px;
            border-radius: 25px;
            text-align: left;
            transition: all 0.3s ease;
            border: 1px solid #fce4ec;
        }

        summary {
            font-family: 'Fredoka', sans-serif;
            font-size: 16px;
            color: #ff3385;
            cursor: pointer;
            list-style: none;
            text-align: center;
        }

        summary::-webkit-details-marker {
            display: none;
        }

        details h3 {
            font-family: 'Fredoka', sans-serif;
            font-size: 16px;
            color: #5bcefa; /* Destaque no azul clarinho */
            margin: 15px 0 5px 0;
            text-shadow: 1px 1px 0px #ffffff;
        }

        details p {
            font-size: 14px;
            color: #7b5969;
            line-height: 1.6;
            margin-top: 5px;
            margin-bottom: 0;
        }

        /* Animação fofa do resultado */
        @keyframes bounceIn {
            0% { opacity: 0; transform: scale(0.9) translateY(10px); }
            50% { opacity: 1; transform: scale(1.05) translateY(-5px); }
            100% { transform: scale(1) translateY(0); }
        }
    </style>
</head>
<body>

    <div class="card">
        <h1>Arcano Pessoal 🎀✨</h1>
        <p class="subtitle">Descubra a sua energia no Tarot 🦋</p>
        
        <div class="input-group">
            <input type="date" id="dataNascimento">
            <button onclick="calcularArcano()">Revelar minha magia 💖</button>
        </div>

        <div id="area-resultado">
            <div id="passos" class="passos-calculo"></div>
            <div id="resultado-final" class="resultado-destaque"></div>
        </div>

        <details>
            <summary>Como funciona a magia? 🏳️‍⚧️✨</summary>
            
            <h3>🌸 Seu mapa de vida</h3>
            <p>O Arcano Pessoal funciona como o seu "signo" no Tarot. Ele revela traços profundos da sua personalidade, seus dons, sua beleza interior e a jornada incrível que você veio trilhar!</p>

            <h3>✨ A matemática mística</h3>
            <p>Pegamos a sua data de nascimento (o dia que o universo ficou mais bonito) e somamos cada número. Se der mais que 22 (o número de Arcanos Maiores), nós somamos de novo até chegar no seu número especial!</p>
        </details>
    </div>

    <script>
        const arcanos = {
            1: "O Mago", 2: "A Sacerdotisa", 3: "A Imperatriz", 4: "O Imperador",
            5: "O Hierofante", 6: "Os Enamorados", 7: "O Carro", 8: "A Justiça",
            9: "O Eremita", 10: "A Roda da Fortuna", 11: "A Força", 12: "O Enforcado",
            13: "A Morte", 14: "A Temperança", 15: "O Diabo", 16: "A Torre",
            17: "A Estrela", 18: "A Lua", 19: "O Sol", 20: "O Julgamento",
            21: "O Mundo", 22: "O Louco"
        };

        function calcularArcano() {
            const dataInput = document.getElementById('dataNascimento').value;
            const areaResultado = document.getElementById('area-resultado');
            const divPassos = document.getElementById('passos');
            const divResultado = document.getElementById('resultado-final');

            if (!dataInput) {
                alert("Amor, não esquece de colocar sua data primeiro! 🎀");
                return;
            }

            areaResultado.style.display = "block";

            const numeros = dataInput.replace(/-/g, '');
            let soma = 0;
            let passosHTML = `<strong>Fazendo a mágica:</strong><br>`;
            let equacaoInicial = [];

            for (let i = 0; i < numeros.length; i++) {
                soma += parseInt(numeros[i]);
                equacaoInicial.push(numeros[i]);
            }
            passosHTML += `${equacaoInicial.join(' + ')} = <strong>${soma}</strong><br>`;

            while (soma > 22) {
                let novaSoma = 0;
                let somaStr = soma.toString();
                let equacaoReducao = [];
                
                for (let i = 0; i < somaStr.length; i++) {
                    novaSoma += parseInt(somaStr[i]);
                    equacaoReducao.push(somaStr[i]);
                }
                passosHTML += `Como ${soma} é maior que 22:<br>${equacaoReducao.join(' + ')} = <strong>${novaSoma}</strong><br>`;
                soma = novaSoma;
            }

            divPassos.innerHTML = passosHTML;
            divResultado.innerHTML = `🌟 ${soma} - ${arcanos[soma]} 🌟`;
        }
    </script>

</body>
</html>
